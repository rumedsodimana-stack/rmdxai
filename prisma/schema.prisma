  propertyId     String
  guestProfileId String
  senderType     String        // guest, staff, system
  senderId       String?
  content        String
  status         MessageStatus @default(SENT)
  isRead         Boolean       @default(false)
  readAt         DateTime?
  createdAt      DateTime      @default(now())

  guestProfile GuestProfile @relation(fields: [guestProfileId], references: [id], onDelete: Cascade)

  @@index([propertyId, guestProfileId])
  @@map("chat_messages")
}

model GuestFeedback {
  id              String   @id @default(uuid())
  propertyId      String
  guestProfileId  String
  reservationId   String?
  overallRating   Int      // 1-10
  cleanlinessRating Int?
  serviceRating   Int?
  locationRating  Int?
  valueRating     Int?
  facilityRating  Int?
  comments        String?
  isPublic        Boolean  @default(false)
  respondedAt     DateTime?
  response        String?
  createdAt       DateTime @default(now())

  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  guestProfile GuestProfile @relation(fields: [guestProfileId], references: [id])

  @@index([propertyId])
  @@map("guest_feedback")
}

// ═══════════════════════════════════════════════════════════
//  MODULE 13: Comms — Internal Communications
// ═══════════════════════════════════════════════════════════

model Message {
  id         String        @id @default(uuid())
  propertyId String
  senderId   String
  recipientIds String[]
  subject    String?
  body       String
  priority   String        @default("normal")
  status     MessageStatus @default(SENT)
  parentId   String?       // for thread replies
  createdAt  DateTime      @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  sender   User     @relation("SentMessages", fields: [senderId], references: [id])

  @@index([propertyId, senderId])
  @@map("messages")
}

model Announcement {
  id           String   @id @default(uuid())
  propertyId   String
  authorId     String
  title        String
  body         String
  targetRoles  UserRole[]
  targetDepts  String[]
  isPinned     Boolean  @default(false)
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id])

  @@index([propertyId])
  @@map("announcements")
}

model NotificationLog {
  id          String              @id @default(uuid())
  propertyId  String
  recipientId String
  channel     NotificationChannel
  subject     String?
  body        String
  isDelivered Boolean             @default(false)
  deliveredAt DateTime?
  error       String?
  referenceType String?
  referenceId   String?
  createdAt   DateTime            @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, recipientId])
  @@map("notification_logs")
}

// ═══════════════════════════════════════════════════════════
//  MODULE 14: OS Kernel — AI Event Bus & Automation
// ═══════════════════════════════════════════════════════════

model AutomationTask {
  id              String          @id @default(uuid())
  propertyId      String
  name            String
  description     String?
  triggerEvent    String
  automationLevel AutomationLevel
  status          TaskStatus      @default(PENDING)
  payload         Json
  result          Json?
  errorMessage    String?
  attempts        Int             @default(0)
  maxAttempts     Int             @default(3)
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  isBlocked       Boolean         @default(false)
  blockedReason   String?
  requiresHuman   Boolean         @default(false)
  humanApprovedBy String?
  humanApprovedAt DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, status])
  @@index([propertyId, triggerEvent])
  @@map("automation_tasks")
}

model EventLog {
  id          String   @id @default(uuid())
  propertyId  String
  eventType   String
  entityType  String
  entityId    String
  payload     Json
  publishedBy String?
  processedBy String[]
  createdAt   DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  actor    User?    @relation(fields: [publishedBy], references: [id])

  @@index([propertyId, eventType])
  @@index([propertyId, entityType, entityId])
  @@map("event_logs")
}

// ═══════════════════════════════════════════════════════════
//  MODULE 15: Multi-Property
// ═══════════════════════════════════════════════════════════

model PropertyGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  headOffice  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members PropertyGroupMember[]

  @@map("property_groups")
}

model PropertyGroupMember {
  id              String   @id @default(uuid())
  propertyGroupId String
  propertyId      String
  role            String   @default("member") // member, flagship, hub
  joinedAt        DateTime @default(now())

  propertyGroup PropertyGroup @relation(fields: [propertyGroupId], references: [id], onDelete: Cascade)
  property      Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyGroupId, propertyId])
  @@map("property_group_members")
}

// ═══════════════════════════════════════════════════════════
//  MODULE 16: Events
// ═══════════════════════════════════════════════════════════

model EventBooking {
  id              String             @id @default(uuid())
  propertyId      String
  bookingNumber   String             @unique
  guestProfileId  String?
  organizerName   String
  organizerEmail  String
  organizerPhone  String?
  eventName       String
  eventType       String             // wedding, conference, gala, meeting, etc.
  status          EventBookingStatus @default(INQUIRY)
  startDateTime   DateTime
  endDateTime     DateTime
  attendeesCount  Int
  venueRooms      String[]
  totalAmount     Decimal            @db.Decimal(12, 2) @default(0)
  depositAmount   Decimal            @db.Decimal(12, 2) @default(0)
  depositPaid     Boolean            @default(false)
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  property       Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  functionSheets FunctionSheet[]
  banquetOrders  BanquetOrder[]

  @@index([propertyId])
  @@map("event_bookings")
}

model FunctionSheet {
  id              String   @id @default(uuid())
  propertyId      String
  eventBookingId  String
  venueName       String
  setupStyle      SetupStyle
  capacityUsed    Int
  startTime       DateTime
  endTime         DateTime
  decorNotes      String?
  avNotes         String?
  cateringNotes   String?
  staffNotes      String?
  setupTime       DateTime?
  breakdownTime   DateTime?
  isConfirmed     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property      Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  eventBooking  EventBooking  @relation(fields: [eventBookingId], references: [id])
  equipmentItems EventEquipment[]
  roomSetups    RoomSetupConfig[]

  @@index([propertyId, eventBookingId])
  @@map("function_sheets")
}

model BanquetOrder {
  id              String   @id @default(uuid())
  propertyId      String
  eventBookingId  String
  orderNumber     String   @unique
  menuPackage     String?
  perPersonCost   Decimal  @db.Decimal(10, 2)
  totalGuests     Int
  totalCost       Decimal  @db.Decimal(10, 2)
  dietaryNotes    String?
  beveragePackage String?
  staffRequired   Int      @default(0)
  notes           String?
  confirmedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  eventBooking EventBooking @relation(fields: [eventBookingId], references: [id])

  @@index([propertyId])
  @@map("banquet_orders")
}

model EventEquipment {
  id              String   @id @default(uuid())
  functionSheetId String
  itemName        String
  category        String   // av, lighting, staging, furniture, etc.
  quantity        Int
  unitCost        Decimal  @db.Decimal(10, 2) @default(0)
  supplier        String?
  notes           String?

  functionSheet FunctionSheet @relation(fields: [functionSheetId], references: [id], onDelete: Cascade)

  @@map("event_equipment")
}

model RoomSetupConfig {
  id              String     @id @default(uuid())
  functionSheetId String
  roomName        String
  setupStyle      SetupStyle
  capacity        Int
  notes           String?

  functionSheet FunctionSheet @relation(fields: [functionSheetId], references: [id], onDelete: Cascade)

  @@map("room_setup_configs")
}
