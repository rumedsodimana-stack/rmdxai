// ──────────────────────────────────────────────────────────────────────────────
//  Singularity PMS — Complete Prisma Schema
//  Multi-tenant hotel property management system
// ──────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════
//  ENUMS
// ═══════════════════════════════════════════════════════════

enum UserRole {
  ADMIN
  GM
  DEPT_MANAGER
  SUPERVISOR
  STAFF
  FINANCE
  GUEST
}

enum RoomStatus {
  CLEAN
  DIRTY
  OUT_OF_ORDER
  INSPECTED
  DO_NOT_DISTURB
  OCCUPIED_CLEAN
  OCCUPIED_DIRTY
}

enum ReservationStatus {
  INQUIRY
  TENTATIVE
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
  WAITLISTED
}

enum FolioStatus {
  OPEN
  CLOSED
  DISPUTED
  VOID
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  READY
  DELIVERED
  CANCELLED
  VOID
}

enum BillStatus {
  OPEN
  PAID
  PARTIALLY_PAID
  VOID
  REFUNDED
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  ROOM_CHARGE
  CITY_LEDGER
  BANK_TRANSFER
  VOUCHER
  LOYALTY_POINTS
  COMPLIMENTARY
}

enum PricingRuleType {
  FIXED
  PERCENTAGE
  DYNAMIC
  YIELD
  LAST_MINUTE
  EARLY_BIRD
  LENGTH_OF_STAY
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalEntryType {
  DEBIT
  CREDIT
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
  SPLIT
  ON_CALL
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  LEAVE
  PUBLIC_HOLIDAY
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  DISPOSED
  LOST
}

enum MaintenanceRequestStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  RESOLVED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkOrderStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AutomationLevel {
  L0
  L1
  L2
  L3
  L4
}

enum TaskStatus {
  PENDING
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  BLOCKED
}

enum ChannelProvider {
  BOOKING_COM
  EXPEDIA
  AIRBNB
  HOTELS_COM
  AGODA
  DIRECT
}

enum SyncStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum NotificationChannel {
  IN_APP
  SMS
  EMAIL
  PUSH
}

enum ServiceRequestStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EventBookingStatus {
  INQUIRY
  PROVISIONAL
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SetupStyle {
  THEATER
  CLASSROOM
  BOARDROOM
  BANQUET
  COCKTAIL
  U_SHAPE
  HOLLOW_SQUARE
  CABARET
}

// ═══════════════════════════════════════════════════════════
//  CORE — Property (Tenant) & Users
// ═══════════════════════════════════════════════════════════

model Property {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  address     String
  city        String
  country     String
  phone       String?
  email       String?
  website     String?
  timezone    String   @default("UTC")
  currency    String   @default("USD")
  logoUrl     String?
  starRating  Int      @default(3)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users              User[]
  roomTypes          RoomType[]
  rooms              Room[]
  reservations       Reservation[]
  folios             Folio[]
  nightAudits        NightAudit[]
  outlets            Outlet[]
  menuItems          MenuItem[]
  orders             Order[]
  bills              Bill[]
  ratePlans          RatePlan[]
  channelConnections ChannelConnection[]
  channelSyncQueue   ChannelSyncQueue[]
  pricingRules       PricingRule[]
  rateForecast       RateForecast[]
  revenueSnapshot    RevenueSnapshot[]
  guestProfiles      GuestProfile[]
  chartOfAccounts    ChartOfAccount[]
  journalEntries     JournalEntry[]
  invoices           Invoice[]
  receipts           Receipt[]
  auditLogs          AuditLog[]
  departments        Department[]
  positions          Position[]
  staff              Staff[]
  shifts             Shift[]
  attendance         Attendance[]
  payrollRuns        PayrollRun[]
  suppliers          Supplier[]
  inventoryItems     InventoryItem[]
  purchaseOrders     PurchaseOrder[]
  assets             Asset[]
  maintenanceReqs    MaintenanceRequest[]
  pmSchedules        PMSchedule[]
  workOrders         WorkOrder[]
  accessLogs         AccessLog[]
  incidentReports    IncidentReport[]
  keyCardAssignments KeyCardAssignment[]
  cctvLogs           CCTVLog[]
  shiftHandovers     ShiftHandover[]
  kpiSnapshots       KPISnapshot[]
  reports            Report[]
  serviceRequests    ServiceRequest[]
  guestFeedback      GuestFeedback[]
  messages           Message[]
  announcements      Announcement[]
  notificationLogs   NotificationLog[]
  automationTasks    AutomationTask[]
  eventLogs          EventLog[]
  eventBookings      EventBooking[]
  functionSheets     FunctionSheet[]
  banquetOrders      BanquetOrder[]
  propertyGroupMemberships PropertyGroupMember[]

  @@map("properties")
}

model User {
  id             String    @id @default(uuid())
  propertyId     String
  email          String
  passwordHash   String
  firstName      String
  lastName       String
  role           UserRole
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  refreshTokenHash String?
  passwordResetToken String?
  passwordResetExpiry DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  property          Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  staffProfile      Staff?
  assignedRequests  MaintenanceRequest[] @relation("AssignedTechnician")
  workOrdersAssigned WorkOrder[]       @relation("AssignedWorker")
  sentMessages      Message[]         @relation("SentMessages")
  announcements     Announcement[]
  auditLogs         AuditLog[]        @relation("ActorAuditLogs")
  accessLogs        AccessLog[]
  shiftHandovers    ShiftHandover[]   @relation("HandoverUser")
  receivedHandovers ShiftHandover[]   @relation("ReceivedHandover")
  eventLogs         EventLog[]

  @@unique([propertyId, email])
  @@index([propertyId])
  @@map("users")
}

// ═══════════════════════════════════════════════════════════
//  MODULE 1: PMS — Property Management System
// ═══════════════════════════════════════════════════════════

model RoomType {
  id            String   @id @default(uuid())
  propertyId    String
  code          String
  name          String
  description   String?
  maxOccupancy  Int
  baseRate      Decimal  @db.Decimal(10, 2)
  amenities     String[]
  bedType       String
  sizeSqm       Decimal? @db.Decimal(6, 2)
  imageUrls     String[]
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  rooms        Room[]
  ratePlans    RatePlan[]

  @@unique([propertyId, code])
  @@index([propertyId])
  @@map("room_types")
}

model Room {
  id           String     @id @default(uuid())
  propertyId   String
  roomTypeId   String
  number       String
  floor        Int
  status       RoomStatus @default(CLEAN)
  isOOO        Boolean    @default(false)
  oooReason    String?
  oooFrom      DateTime?
  oooUntil     DateTime?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomType     RoomType     @relation(fields: [roomTypeId], references: [id])
  reservations Reservation[]
  keyCards     KeyCardAssignment[]
  workOrders   WorkOrder[]

  @@unique([propertyId, number])
  @@index([propertyId])
  @@index([propertyId, status])
  @@map("rooms")
}

model Reservation {
  id               String            @id @default(uuid())
  propertyId       String
  guestProfileId   String?
  roomId           String?
  roomTypeId       String?
  confirmationNo   String            @unique
  status           ReservationStatus @default(CONFIRMED)
  source           String            @default("DIRECT")
  channelBookingRef String?
  checkInDate      DateTime
  checkOutDate     DateTime
  adults           Int               @default(1)
  children         Int               @default(0)
  rateCode         String?
  rateAmount       Decimal           @db.Decimal(10, 2)
  totalAmount      Decimal           @db.Decimal(10, 2)
  depositAmount    Decimal           @db.Decimal(10, 2) @default(0)
  depositPaid      Boolean           @default(false)
  specialRequests  String?
  arrivalTime      String?
  actualCheckIn    DateTime?
  actualCheckOut   DateTime?
  checkedInById    String?
  checkedOutById   String?
  cancelledAt      DateTime?
  cancellationReason String?
  noShowAt         DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  property      Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  guestProfile  GuestProfile? @relation(fields: [guestProfileId], references: [id])
  room          Room?        @relation(fields: [roomId], references: [id])
  folio         Folio?

  @@index([propertyId])
  @@index([propertyId, status])
  @@index([propertyId, checkInDate, checkOutDate])
  @@map("reservations")
}

model Folio {
  id            String      @id @default(uuid())
  propertyId    String
  reservationId String      @unique
  guestProfileId String?
  folioNumber   String      @unique
  status        FolioStatus @default(OPEN)
  totalCharges  Decimal     @db.Decimal(10, 2) @default(0)
  totalPayments Decimal     @db.Decimal(10, 2) @default(0)
  balance       Decimal     @db.Decimal(10, 2) @default(0)
  closedAt      DateTime?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservation  Reservation  @relation(fields: [reservationId], references: [id])
  guestProfile GuestProfile? @relation(fields: [guestProfileId], references: [id])
  items        FolioItem[]

  @@index([propertyId])
  @@map("folios")
}

model FolioItem {
  id            String      @id @default(uuid())
  folioId       String
  description   String
  quantity      Decimal     @db.Decimal(8, 2) @default(1)
  unitPrice     Decimal     @db.Decimal(10, 2)
  amount        Decimal     @db.Decimal(10, 2)
  taxAmount     Decimal     @db.Decimal(10, 2) @default(0)
  isVoid        Boolean     @default(false)
  voidReason    String?
  voidedAt      DateTime?
  isComp        Boolean     @default(false)
  compReason    String?
  referenceType String?
  referenceId   String?
  postedAt      DateTime    @default(now())
  postedById    String?

  folio         Folio       @relation(fields: [folioId], references: [id], onDelete: Cascade)

  @@index([folioId])
  @@map("folio_items")
}

model NightAudit {
  id           String   @id @default(uuid())
  propertyId   String
  auditDate    DateTime
  totalRooms   Int
  occupiedRooms Int
  occupancyPct Decimal  @db.Decimal(5, 2)
  adr          Decimal  @db.Decimal(10, 2)
  revpar       Decimal  @db.Decimal(10, 2)
  totalRevenue Decimal  @db.Decimal(12, 2)
  roomRevenue  Decimal  @db.Decimal(12, 2)
  fbRevenue    Decimal  @db.Decimal(12, 2)
  otherRevenue Decimal  @db.Decimal(12, 2)
  runById      String?
  completedAt  DateTime?
  notes        String?
  createdAt    DateTime @default(now())

  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, auditDate])
  @@index([propertyId])
  @@map("night_audits")
}

// ═══════════════════════════════════════════════════════════
//  MODULE 2: POS — Point of Sale
// ═══════════════════════════════════════════════════════════

model Outlet {
  id           String   @id @default(uuid())
  propertyId   String
  name         String
  type         String   // restaurant, bar, room_service, spa, pool_bar, etc.
  location     String?
  isActive     Boolean  @default(true)
  openTime     String?
  closeTime    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  property     Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  menuItems    MenuItem[]
  orders       Order[]

  @@index([propertyId])
  @@map("outlets")
}

model MenuItem {
  id           String   @id @default(uuid())
  propertyId   String
  outletId     String
  name         String
  description  String?
  category     String
  subCategory  String?
  price        Decimal  @db.Decimal(10, 2)
  taxRate      Decimal  @db.Decimal(5, 2) @default(0)
  isAvailable  Boolean  @default(true)
  isVegetarian Boolean  @default(false)
  allergens    String[]
  imageUrl     String?
  prepTimeMin  Int?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  property    Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  outlet      Outlet      @relation(fields: [outletId], references: [id])
  orderItems  OrderItem[]

  @@index([propertyId])
  @@index([outletId])
  @@map("menu_items")
}

model Order {
  id            String      @id @default(uuid())
  propertyId    String
  outletId      String
  orderNumber   String      @unique
  guestProfileId String?
  roomNumber    String?
  tableNumber   String?
  status        OrderStatus @default(PENDING)
  type          String      @default("dine_in") // dine_in, takeaway, room_service, delivery
  subtotal      Decimal     @db.Decimal(10, 2) @default(0)
  taxAmount     Decimal     @db.Decimal(10, 2) @default(0)
  serviceCharge Decimal     @db.Decimal(10, 2) @default(0)
  total         Decimal     @db.Decimal(10, 2) @default(0)
  notes         String?
  servedById    String?
  isVoid        Boolean     @default(false)
  voidReason    String?
  voidedAt      DateTime?
  isComp        Boolean     @default(false)
  compReason    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  property     Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  outlet       Outlet      @relation(fields: [outletId], references: [id])
  items        OrderItem[]
  bill         Bill?

  @@index([propertyId])
  @@index([outletId])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  menuItemId  String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  totalPrice  Decimal  @db.Decimal(10, 2)
  modifiers   String[]
  notes       String?
  isVoid      Boolean  @default(false)
  voidReason  String?

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model Bill {
  id            String      @id @default(uuid())
  propertyId    String
  orderId       String      @unique
  billNumber    String      @unique
  status        BillStatus  @default(OPEN)
  subtotal      Decimal     @db.Decimal(10, 2)
  taxAmount     Decimal     @db.Decimal(10, 2)
  serviceCharge Decimal     @db.Decimal(10, 2)
  total         Decimal     @db.Decimal(10, 2)
  amountPaid    Decimal     @db.Decimal(10, 2) @default(0)
  balance       Decimal     @db.Decimal(10, 2) @default(0)
  paymentMethod PaymentMethod?
  splitDetails  Json?
  folioChargeId String?
  closedAt      DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  order    Order    @relation(fields: [orderId], references: [id])

  @@index([propertyId])
  @@map("bills")
}

// ═══════════════════════════════════════════════════════════
//  MODULE 3: Channel Manager
// ═══════════════════════════════════════════════════════════

model RatePlan {
  id              String   @id @default(uuid())
  propertyId      String
  roomTypeId      String
  code            String
  name            String
  description     String?
  baseRate        Decimal  @db.Decimal(10, 2)
  mealPlan        String   @default("room_only") // room_only, bb, hb, fb, ai
  minLOS          Int      @default(1)
  maxLOS          Int?
  advanceBooking  Int?     // days in advance required
  cancellationPolicy String?
  isActive        Boolean  @default(true)
  validFrom       DateTime?
  validUntil      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property     Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomType     RoomType            @relation(fields: [roomTypeId], references: [id])
  channelRates ChannelRateMapping[]

  @@unique([propertyId, code])
  @@index([propertyId])
  @@map("rate_plans")
}

model ChannelConnection {
  id              String          @id @default(uuid())
  propertyId      String
  provider        ChannelProvider
  hotelId         String          // our ID on the OTA platform
  credentials     Json            // encrypted API keys/tokens
  isActive        Boolean         @default(true)
  lastSyncedAt    DateTime?
  syncErrors      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  property         Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  channelRateMaps  ChannelRateMapping[]
  availabilityBlocks AvailabilityBlock[]

  @@unique([propertyId, provider])
  @@index([propertyId])
  @@map("channel_connections")
}

model ChannelRateMapping {
  id                  String            @id @default(uuid())
  channelConnectionId String
  ratePlanId          String
  channelRateCode     String
  markup              Decimal           @db.Decimal(5, 2) @default(0)
  isActive            Boolean           @default(true)
  createdAt           DateTime          @default(now())

  channelConnection ChannelConnection @relation(fields: [channelConnectionId], references: [id], onDelete: Cascade)
  ratePlan          RatePlan          @relation(fields: [ratePlanId], references: [id])

  @@map("channel_rate_mappings")
}

model AvailabilityBlock {
  id                  String   @id @default(uuid())
  propertyId          String
  channelConnectionId String
  roomTypeId          String
  date                DateTime
  availableRooms      Int
  rate                Decimal  @db.Decimal(10, 2)
  isClosed            Boolean  @default(false)
  minLOS              Int?
  maxLOS              Int?
  ctaRestriction      Boolean  @default(false) // closed to arrival
  ctdRestriction      Boolean  @default(false) // closed to departure
  updatedAt           DateTime @updatedAt

  channelConnection ChannelConnection @relation(fields: [channelConnectionId], references: [id], onDelete: Cascade)

  @@unique([channelConnectionId, roomTypeId, date])
  @@index([propertyId, date])
  @@map("availability_blocks")
}

model ChannelSyncQueue {
  id           String     @id @default(uuid())
  propertyId   String
  syncType     String     // rates, availability, reservation, cancellation
  payload      Json
  status       SyncStatus @default(PENDING)
  attempts     Int        @default(0)
  lastError    String?
  processedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, status])
  @@map("channel_sync_queue")
}

// ═══════════════════════════════════════════════════════════
//  MODULE 4: RMS — Revenue Management System
// ═══════════════════════════════════════════════════════════

model PricingRule {
  id             String          @id @default(uuid())
  propertyId     String
  name           String
  type           PricingRuleType
  roomTypeId     String?
  triggerMetric  String?         // occupancy_pct, days_to_arrival, competitor_rate
  triggerValue   Decimal?        @db.Decimal(10, 2)
  adjustmentType String          @default("percentage") // percentage, fixed
  adjustmentValue Decimal        @db.Decimal(10, 2)
  minRate        Decimal?        @db.Decimal(10, 2)
  maxRate        Decimal?        @db.Decimal(10, 2)
  priority       Int             @default(10)
  isActive       Boolean         @default(true)
  validFrom      DateTime?
  validUntil     DateTime?
  daysOfWeek     Int[]           // 0=Sun..6=Sat
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("pricing_rules")
}

model RateForecast {
  id             String   @id @default(uuid())
  propertyId     String
  forecastDate   DateTime
  roomTypeId     String?
  predictedOccupancy Decimal @db.Decimal(5, 2)
  predictedADR   Decimal  @db.Decimal(10, 2)
  predictedRevPAR Decimal @db.Decimal(10, 2)
  recommendedRate Decimal @db.Decimal(10, 2)
  confidenceScore Decimal @db.Decimal(5, 2) @default(0)
  modelVersion   String?
  createdAt      DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, forecastDate, roomTypeId])
  @@index([propertyId, forecastDate])
  @@map("rate_forecasts")
}

model RevenueSnapshot {
  id              String   @id @default(uuid())
  propertyId      String
  snapshotDate    DateTime
  totalRooms      Int
  occupiedRooms   Int
  outOfOrderRooms Int      @default(0)
  occupancyPct    Decimal  @db.Decimal(5, 2)
  adr             Decimal  @db.Decimal(10, 2)
  revpar          Decimal  @db.Decimal(10, 2)
  goppar          Decimal  @db.Decimal(10, 2) @default(0)
  totalRevenue    Decimal  @db.Decimal(12, 2)
  roomRevenue     Decimal  @db.Decimal(12, 2)
  fbRevenue       Decimal  @db.Decimal(12, 2)
  otherRevenue    Decimal  @db.Decimal(12, 2)
  totalExpenses   Decimal  @db.Decimal(12, 2) @default(0)
  gopAmount       Decimal  @db.Decimal(12, 2) @default(0)
  createdAt       DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, snapshotDate])
  @@index([propertyId])
  @@map("revenue_snapshots")
}

// ═══════════════════════════════════════════════════════════
//  MODULE 5: CRM — Customer Relationship Management
// ═══════════════════════════════════════════════════════════

model GuestProfile {
  id             String       @id @default(uuid())
  propertyId     String
  firstName      String
  lastName       String
  email          String?
  phone          String?
  nationality    String?
  passportNo     String?
  passportExpiry DateTime?
  dateOfBirth    DateTime?
  address        String?
  city           String?
  country        String?
  language       String       @default("en")
  loyaltyTier    LoyaltyTier  @default(BRONZE)
  loyaltyPoints  Int          @default(0)
  totalStays     Int          @default(0)
  totalSpend     Decimal      @db.Decimal(12, 2) @default(0)
  isVip          Boolean      @default(false)
  vipReason      String?
  // Blacklist is NEVER automated — manual only
  isBlacklisted  Boolean      @default(false)
  blacklistReason String?
  blacklistedAt  DateTime?
  blacklistedById String?     // must be manually entered by authorised user
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  property      Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservations  Reservation[]
  folios        Folio[]
  preferences   GuestPreference[]
  guestNotes    GuestNote[]
  loyalty       LoyaltyTransaction[]
  serviceRequests ServiceRequest[]
  chatMessages  ChatMessage[]
  feedback      GuestFeedback[]

  @@index([propertyId])
  @@index([propertyId, email])
  @@map("guest_profiles")
}

model GuestPreference {
  id             String   @id @default(uuid())
  guestProfileId String
  category       String   // room, pillow, temperature, dietary, transport, etc.
  preference     String
  notes          String?
  createdAt      DateTime @default(now())

  guestProfile GuestProfile @relation(fields: [guestProfileId], references: [id], onDelete: Cascade)

  @@index([guestProfileId])
  @@map("guest_preferences")
}

model GuestNote {
  id             String   @id @default(uuid())
  guestProfileId String
  authorId       String
  type           String   @default("general") // general, complaint, compliment, request, incident
  content        String
  isPrivate      Boolean  @default(false)
  createdAt      DateTime @default(now())

  guestProfile GuestProfile @relation(fields: [guestProfileId], references: [id], onDelete: Cascade)

  @@index([guestProfileId])
  @@map("guest_notes")
}

model LoyaltyTransaction {
  id             String   @id @default(uuid())
  guestProfileId String
  type           String   // earn, redeem, expire, adjust
  points         Int
  balanceAfter   Int
  description    String
  referenceType  String?  // reservation, purchase, adjustment
  referenceId    String?
  createdAt      DateTime @default(now())

  guestProfile GuestProfile @relation(fields: [guestProfileId], references: [id], onDelete: Cascade)

  @@index([guestProfileId])
  @@map("loyalty_transactions")
}

// ═══════════════════════════════════════════════════════════
//  MODULE 6: Finance
// ═══════════════════════════════════════════════════════════

model ChartOfAccount {
  id           String      @id @default(uuid())
  propertyId   String
  code         String
  name         String
  type         AccountType
  parentId     String?
  description  String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  property    Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  parent      ChartOfAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    ChartOfAccount[] @relation("AccountHierarchy")
  journalLines JournalLine[]

  @@unique([propertyId, code])
  @@index([propertyId])
  @@map("chart_of_accounts")
}

model JournalEntry {
  id            String   @id @default(uuid())
  propertyId    String
  entryNumber   String   @unique
  description   String
  referenceType String?  // folio, invoice, payroll, purchase_order, adjustment
  referenceId   String?
  entryDate     DateTime
  postedById    String
  isReversed    Boolean  @default(false)
  reversalId    String?
  createdAt     DateTime @default(now())

  property Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  lines    JournalLine[]

  @@index([propertyId])
  @@index([propertyId, entryDate])
  @@map("journal_entries")
}

model JournalLine {
  id             String           @id @default(uuid())
  journalEntryId String
  accountId      String
  type           JournalEntryType
  amount         Decimal          @db.Decimal(12, 2)
  description    String?

  journalEntry JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      ChartOfAccount @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@map("journal_lines")
}

model Invoice {
  id           String        @id @default(uuid())
  propertyId   String
  invoiceNumber String        @unique
  guestProfileId String?
  companyName  String?
  dueDate      DateTime
  status       InvoiceStatus @default(DRAFT)
  subtotal     Decimal       @db.Decimal(12, 2)
  taxAmount    Decimal       @db.Decimal(12, 2)
  total        Decimal       @db.Decimal(12, 2)
  amountPaid   Decimal       @db.Decimal(12, 2) @default(0)
  balance      Decimal       @db.Decimal(12, 2)
  notes        String?
  paidAt       DateTime?
  sentAt       DateTime?
  createdById  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  property  Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  receipts  Receipt[]

  @@index([propertyId])
  @@map("invoices")
}

model Receipt {
  id            String        @id @default(uuid())
  propertyId    String
  invoiceId     String?
  receiptNumber String        @unique
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  reference     String?
  notes         String?
  createdById   String
  createdAt     DateTime      @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  invoice  Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([propertyId])
  @@map("receipts")
}

// Immutable audit log — no updates, no deletes at DB level
model AuditLog {
  id           String   @id @default(uuid())
  propertyId   String
  actorId      String
  actorRole    String
  action       String
  entityType   String
  entityId     String
  oldValues    Json?
  newValues    Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  actor    User     @relation("ActorAuditLogs", fields: [actorId], references: [id])

  @@index([propertyId])
  @@index([propertyId, entityType, entityId])
  @@index([actorId])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════════
//  MODULE 7: HCM — Human Capital Management
// ═══════════════════════════════════════════════════════════

model Department {
  id         String   @id @default(uuid())
  propertyId String
  name       String
  code       String
  managerId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property   Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  positions  Position[]
  staff      Staff[]

  @@unique([propertyId, code])
  @@index([propertyId])
  @@map("departments")
}

model Position {
  id           String   @id @default(uuid())
  propertyId   String
  departmentId String
  title        String
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id])
  staff      Staff[]

  @@index([propertyId])
  @@map("positions")
}

model Staff {
  id              String   @id @default(uuid())
  propertyId      String
  userId          String   @unique
  departmentId    String
  positionId      String
  employeeNumber  String
  firstName       String
  lastName        String
  email           String
  phone           String?
  hireDate        DateTime
  terminationDate DateTime?
  baseSalary      Decimal  @db.Decimal(12, 2)
  bankAccountNo   String?
  emergencyContact Json?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property   Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
  position   Position   @relation(fields: [positionId], references: [id])
  shifts     Shift[]    @relation("StaffShifts")
  attendance Attendance[]
  payrollItems PayrollItem[]

  @@unique([propertyId, employeeNumber])
  @@index([propertyId])
  @@map("staff")
}

model Shift {
  id          String    @id @default(uuid())
  propertyId  String
  staffId     String
  type        ShiftType
  startTime   DateTime
  endTime     DateTime
  breakMinutes Int      @default(0)
  notes       String?
  isConfirmed Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  property   Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  staff      Staff      @relation("StaffShifts", fields: [staffId], references: [id])
  attendance Attendance[]

  @@index([propertyId, staffId])
  @@index([propertyId, startTime])
  @@map("shifts")
}

model Attendance {
  id         String           @id @default(uuid())
  propertyId String
  staffId    String
  shiftId    String?
  date       DateTime
  clockIn    DateTime?
  clockOut   DateTime?
  status     AttendanceStatus
  hoursWorked Decimal         @db.Decimal(5, 2) @default(0)
  overtime   Decimal          @db.Decimal(5, 2) @default(0)
  notes      String?
  approvedById String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  staff    Staff    @relation(fields: [staffId], references: [id])
  shift    Shift?   @relation(fields: [shiftId], references: [id])

  @@index([propertyId, staffId, date])
  @@map("attendance")
}

model PayrollRun {
  id           String   @id @default(uuid())
  propertyId   String
  periodStart  DateTime
  periodEnd    DateTime
  runDate      DateTime
  totalGross   Decimal  @db.Decimal(12, 2)
  totalDeductions Decimal @db.Decimal(12, 2) @default(0)
  totalNet     Decimal  @db.Decimal(12, 2)
  status       String   @default("draft") // draft, approved, paid
  approvedById String?
  approvedAt   DateTime?
  paidAt       DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  payrollItems PayrollItem[]

  @@index([propertyId])
  @@map("payroll_runs")
}

model PayrollItem {
  id           String   @id @default(uuid())
  payrollRunId String
  staffId      String
  grossPay     Decimal  @db.Decimal(12, 2)
  overtime     Decimal  @db.Decimal(12, 2) @default(0)
  bonuses      Decimal  @db.Decimal(12, 2) @default(0)
  deductions   Decimal  @db.Decimal(12, 2) @default(0)
  taxes        Decimal  @db.Decimal(12, 2) @default(0)
  netPay       Decimal  @db.Decimal(12, 2)
  breakdown    Json?

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  staff      Staff      @relation(fields: [staffId], references: [id])

  @@map("payroll_items")
}

// ═══════════════════════════════════════════════════════════
//  MODULE 8: Procurement
// ═══════════════════════════════════════════════════════════

model Supplier {
  id           String   @id @default(uuid())
  propertyId   String
  name         String
  contactName  String?
  email        String?
  phone        String?
  address      String?
  taxId        String?
  paymentTerms String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  property       Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]
  inventoryItems InventoryItem[]

  @@index([propertyId])
  @@map("suppliers")
}

model InventoryItem {
  id              String   @id @default(uuid())
  propertyId      String
  supplierId      String?
  sku             String
  name            String
  description     String?
  category        String
  unit            String   @default("each")
  currentStock    Decimal  @db.Decimal(10, 2) @default(0)
  reorderPoint    Decimal  @db.Decimal(10, 2)
  reorderQty      Decimal  @db.Decimal(10, 2)
  unitCost        Decimal  @db.Decimal(10, 2)
  lastPurchaseDate DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property         Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  supplier         Supplier?         @relation(fields: [supplierId], references: [id])
  purchaseOrderItems PurchaseOrderItem[]
  goodsReceiptItems GoodsReceiptItem[]

  @@unique([propertyId, sku])
  @@index([propertyId])
  @@map("inventory_items")
}

model PurchaseOrder {
  id           String              @id @default(uuid())
  propertyId   String
  supplierId   String
  orderNumber  String              @unique
  status       PurchaseOrderStatus @default(DRAFT)
  orderDate    DateTime
  expectedDate DateTime?
  totalAmount  Decimal             @db.Decimal(12, 2)
  notes        String?
  approvedById String?
  approvedAt   DateTime?
  createdById  String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  property     Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  supplier     Supplier           @relation(fields: [supplierId], references: [id])
  items        PurchaseOrderItem[]
  goodsReceipts GoodsReceipt[]

  @@index([propertyId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  inventoryItemId String
  quantity        Decimal       @db.Decimal(10, 2)
  unitPrice       Decimal       @db.Decimal(10, 2)
  totalPrice      Decimal       @db.Decimal(10, 2)
  receivedQty     Decimal       @db.Decimal(10, 2) @default(0)
  notes           String?

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@map("purchase_order_items")
}

model GoodsReceipt {
  id              String   @id @default(uuid())
  purchaseOrderId String
  receivedById    String
  receivedDate    DateTime
  notes           String?
  createdAt       DateTime @default(now())

  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  items         GoodsReceiptItem[]

  @@map("goods_receipts")
}

model GoodsReceiptItem {
  id              String   @id @default(uuid())
  goodsReceiptId  String
  inventoryItemId String
  quantity        Decimal  @db.Decimal(10, 2)
  unitCost        Decimal  @db.Decimal(10, 2)
  notes           String?

  goodsReceipt  GoodsReceipt  @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@map("goods_receipt_items")
}

// ═══════════════════════════════════════════════════════════
//  MODULE 9: BMS — Building Management System
// ═══════════════════════════════════════════════════════════

model Asset {
  id              String      @id @default(uuid())
  propertyId      String
  name            String
  assetTag        String
  category        String      // hvac, elevator, electrical, plumbing, furniture, it, kitchen, etc.
  location        String
  manufacturer    String?
  model           String?
  serialNumber    String?
  purchaseDate    DateTime?
  purchaseCost    Decimal?    @db.Decimal(12, 2)
  warrantyExpiry  DateTime?
  status          AssetStatus @default(ACTIVE)
  nextServiceDate DateTime?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  property         Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  maintenanceReqs  MaintenanceRequest[]
  pmSchedules      PMSchedule[]
  workOrders       WorkOrder[]

  @@unique([propertyId, assetTag])
  @@index([propertyId])
  @@map("assets")
}

model MaintenanceRequest {
  id           String                   @id @default(uuid())
  propertyId   String
  assetId      String?
  roomId       String?
  title        String
  description  String
  priority     MaintenancePriority      @default(MEDIUM)
  status       MaintenanceRequestStatus @default(OPEN)
  reportedById String
  assignedToId String?
  resolvedAt   DateTime?
  resolution   String?
  imageUrls    String[]
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  property    Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  asset       Asset?      @relation(fields: [assetId], references: [id])
  assignedTo  User?       @relation("AssignedTechnician", fields: [assignedToId], references: [id])
  workOrders  WorkOrder[]

  @@index([propertyId, status])
  @@map("maintenance_requests")
}

model PMSchedule {
  id               String   @id @default(uuid())
  propertyId       String
  assetId          String
  name             String
  description      String?
  frequencyDays    Int
  lastPerformedAt  DateTime?
  nextDueDate      DateTime
  estimatedMinutes Int      @default(60)
  assignedDeptId   String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  asset      Asset    @relation(fields: [assetId], references: [id])
  workOrders WorkOrder[]

  @@index([propertyId, nextDueDate])
  @@map("pm_schedules")
}

model WorkOrder {
  id                  String          @id @default(uuid())
  propertyId          String
  maintenanceRequestId String?
  pmScheduleId        String?
  assetId             String?
  roomId              String?
  orderNumber         String          @unique
  title               String
  description         String
  status              WorkOrderStatus @default(ASSIGNED)
  assignedToId        String
  startedAt           DateTime?
  completedAt         DateTime?
  laborMinutes        Int?
  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  property            Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  maintenanceRequest  MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id])
  pmSchedule          PMSchedule?        @relation(fields: [pmScheduleId], references: [id])
  asset               Asset?             @relation(fields: [assetId], references: [id])
  room                Room?              @relation(fields: [roomId], references: [id])
  assignedTo          User               @relation("AssignedWorker", fields: [assignedToId], references: [id])

  @@index([propertyId, status])
  @@map("work_orders")
}

// ═══════════════════════════════════════════════════════════
//  MODULE 10: Security
// ═══════════════════════════════════════════════════════════

model AccessLog {
  id         String   @id @default(uuid())
  propertyId String
  userId     String?
  location   String
  accessType String   // entry, exit, denied
  method     String   // key_card, pin, biometric, manual
  cardNumber String?
  timestamp  DateTime @default(now())
  notes      String?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])

  @@index([propertyId, timestamp])
  @@map("access_logs")
}

model IncidentReport {
  id           String           @id @default(uuid())
  propertyId   String
  reportNumber String           @unique
  title        String
  description  String
  severity     IncidentSeverity @default(MEDIUM)
  location     String?
  guestProfileId String?
  reportedById String
  assignedToId String?
  witnessNames String[]
  status       String           @default("open") // open, investigating, resolved, closed
  resolution   String?
  resolvedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("incident_reports")
}

model KeyCardAssignment {
  id             String   @id @default(uuid())
  propertyId     String
  roomId         String?
  guestProfileId String?
  cardNumber     String
  issuedAt       DateTime @default(now())
  expiresAt      DateTime
  isActive       Boolean  @default(true)
  returnedAt     DateTime?
  issuedById     String
  notes          String?
  // Key issuance without ID verification is a HARD limit — enforced in service layer

  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room         Room?         @relation(fields: [roomId], references: [id])

  @@index([propertyId])
  @@map("key_card_assignments")
}

// CCTV log is reference-only — no footage stored in DB
model CCTVLog {
  id           String   @id @default(uuid())
  propertyId   String
  cameraId     String
  location     String
  eventTime    DateTime
  description  String
  incidentId   String?
  requestedById String?
  createdAt    DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, eventTime])
  @@map("cctv_logs")
}

model ShiftHandover {
  id            String   @id @default(uuid())
  propertyId    String
  fromUserId    String
  toUserId      String
  shiftDate     DateTime
  summary       String
  openIssues    String?
  pendingTasks  String?
  guestNotes    String?
  cashBalance   Decimal? @db.Decimal(10, 2)
  createdAt     DateTime @default(now())

  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  fromUser  User     @relation("HandoverUser", fields: [fromUserId], references: [id])
  toUser    User     @relation("ReceivedHandover", fields: [toUserId], references: [id])

  @@index([propertyId, shiftDate])
  @@map("shift_handovers")
}

// ═══════════════════════════════════════════════════════════
//  MODULE 11: Analytics
// ═══════════════════════════════════════════════════════════

model KPISnapshot {
  id            String   @id @default(uuid())
  propertyId    String
  period        String   // daily, weekly, monthly
  periodDate    DateTime
  occupancyPct  Decimal  @db.Decimal(5, 2)
  adr           Decimal  @db.Decimal(10, 2)
  revpar        Decimal  @db.Decimal(10, 2)
  goppar        Decimal  @db.Decimal(10, 2)
  totalRevenue  Decimal  @db.Decimal(12, 2)
  fbRevenue     Decimal  @db.Decimal(12, 2)
  otherRevenue  Decimal  @db.Decimal(12, 2)
  totalArrivals Int
  totalDepartures Int
  cancellations Int
  noShows       Int
  avgLOS        Decimal  @db.Decimal(5, 2)
  createdAt     DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, period, periodDate])
  @@index([propertyId, period, periodDate])
  @@map("kpi_snapshots")
}

model Report {
  id          String   @id @default(uuid())
  propertyId  String
  name        String
  type        String   // occupancy, revenue, hcm, procurement, etc.
  period      String
  fromDate    DateTime
  toDate      DateTime
  data        Json
  exportUrl   String?
  createdById String
  createdAt   DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, type])
  @@map("reports")
}

// ═══════════════════════════════════════════════════════════
//  MODULE 12: Guest App
// ═══════════════════════════════════════════════════════════

model ServiceRequest {
  id             String               @id @default(uuid())
  propertyId     String
  guestProfileId String
