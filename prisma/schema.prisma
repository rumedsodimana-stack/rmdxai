  category       String               // housekeeping, maintenance, f&b, concierge, transport, etc.
  title          String
  description    String
  status         ServiceRequestStatus @default(OPEN)
  priority       String               @default("normal")
  assignedToId   String?
  completedAt    DateTime?
  rating         Int?
