# ──────────────────────────────────────────────
#  Singularity PMS — Environment Variables
# ──────────────────────────────────────────────

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/singularity_pms?schema=public"

# JWT
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_REFRESH_EXPIRES_IN="7d"

# Redis (BullMQ)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# Server
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# OTA Channels (placeholder keys)
BOOKING_COM_API_KEY=""
EXPEDIA_API_KEY=""
AIRBNB_API_KEY=""
